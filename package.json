{
  "name": "london-live",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/bundle-properties.cjs",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "data:boundaries": "tsx scripts/fetch-boundaries.ts",
    "data:centroids": "tsx scripts/compute-centroids.ts",
    "data:stations": "tsx scripts/fetch-stations.ts",
    "data:graph": "tsx scripts/build-transport-graph.ts",
    "data:sectors": "tsx scripts/fetch-sector-boundaries.ts",
    "data:boundary": "tsx scripts/compute-london-boundary.ts",
    "data:properties": "tsx scripts/fetch-property-prices.ts",
    "data:amenities": "tsx scripts/fetch-amenities.ts",
    "data:all": "npm run data:boundaries && npm run data:centroids && npm run data:stations && npm run data:sectors && npm run data:graph && npm run data:boundary"
  },
  "dependencies": {
    "d3-interpolate": "^3.0.1",
    "d3-scale": "^4.0.2",
    "d3-scale-chromatic": "^3.1.0",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@turf/turf": "^7.3.4",
    "@types/d3-interpolate": "^3.0.4",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-scale-chromatic": "^3.1.0",
    "@types/geojson": "^7946.0.16",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  }
}
